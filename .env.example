# OpenAI (embeddings)
OPENAI_API_KEY=

# MiniMax (chat LLM por defecto)
MINIMAX_API_KEY=

# Modelos
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=MiniMax-M2.7
# CHAT_MODEL=gpt-4.1-mini

# Vector store
VECTOR_BACKEND=chroma
# CHROMA_PATH=./data/indexes/chroma   # override opcional; en Docker se fija a /app/data/indexes/chroma

# URL pública de la API para el frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
